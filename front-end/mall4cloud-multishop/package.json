{
  "name": "mall4cloud-multishop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt src vite.config.js",
    "format:check": "oxfmt --check src vite.config.js",
    "lint": "oxlint src vite.config.js",
    "lint:fix": "oxlint --fix src vite.config.js",
    "lint:staged": "lint-staged --concurrent false"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "axios": "1.15.2",
    "big.js": "7.0.1",
    "clipboard": "2.0.11",
    "crypto-js": "4.2.0",
    "default-passive-events": "4.0.0",
    "dompurify": "3.4.1",
    "echarts": "6.0.0",
    "element-plus": "2.14.1",
    "js-base64": "3.7.5",
    "moment": "2.30.1",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "qs": "6.15.1",
    "vue": "3.5.32",
    "vue-cookies": "1.8.6",
    "vue-draggable-next": "2.3.0",
    "vue-i18n": "11.3.2",
    "vue-router": "5.0.4",
    "vue-slicksort": "2.0.5",
    "vuedraggable": "4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.6",
    "fast-glob": "3.3.3",
    "lint-staged": "16.4.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "sass": "1.99.0",
    "terser": "5.46.1",
    "unplugin-auto-import": "21.0.0",
    "unplugin-vue-components": "32.0.0",
    "vite": "8.0.9",
    "vite-plugin-compression2": "2.5.3",
    "vite-plugin-svg-icons": "2.0.1"
  },
  "lint-staged": {
    "*.{css,html,js,json,jsonc,md,scss,vue}": [
      "oxfmt"
    ],
    "*.{js,vue}": [
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=8 <11"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "sortablejs*"
      ]
    }
  }
}
